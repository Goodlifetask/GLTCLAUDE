{
  "name": "goodlifetask",
  "version": "1.0.0",
  "private": true,
  "description": "GoodLifeTask - Cross-platform reminder & productivity application",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "npm run --workspace=@glt/api prisma:migrate",
    "db:seed": "npm run --workspace=@glt/api db:seed",
    "db:studio": "npm run --workspace=@glt/api prisma:studio",
    "api:dev": "npm run --workspace=@glt/api dev",
    "web:dev": "npm run --workspace=@glt/web dev"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
