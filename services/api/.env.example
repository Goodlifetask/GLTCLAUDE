# ─── GoodLifeTask API — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in values for local development.
# Never commit .env to version control.

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
API_URL=http://localhost:3001

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://glt_user:glt_dev_password@localhost:5432/goodlifetask

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://:glt_redis_password@localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-with-64-char-random-hex-string-for-local-dev-only
JWT_ISSUER=goodlifetask.com
JWT_AUDIENCE=goodlifetask-api
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000

# ─── OAuth ───────────────────────────────────────────────────────────────────
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple: https://developer.apple.com/account/resources/identifiers/list
APPLE_CLIENT_ID=com.goodlifetask.app
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
APPLE_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"

# Microsoft: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# ─── Stripe ──────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_TEAM_MONTHLY_PRICE_ID=price_...
STRIPE_TEAM_YEARLY_PRICE_ID=price_...

# ─── RevenueCat ──────────────────────────────────────────────────────────────
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# ─── Firebase (FCM) ──────────────────────────────────────────────────────────
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─── APNs (Apple Push Notifications) ─────────────────────────────────────────
# Generate at: https://developer.apple.com/account/resources/authkeys/list
APNS_KEY_ID=YOUR_APNS_KEY_ID
APNS_TEAM_ID=YOUR_APPLE_TEAM_ID
APNS_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"
APNS_BUNDLE_ID=com.goodlifetask.app
APNS_PRODUCTION=false

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=admin@goodlifetask.com

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=notifications@goodlifetask.com
EMAIL_FROM_NAME=GoodLifeTask

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=glt-dev-uploads
S3_CDN_URL=https://cdn.goodlifetask.dev

# ─── Encryption ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32 (gives 64 hex chars = 32 bytes)
ENCRYPTION_KEY=replace-with-64-char-hex-string-for-aes256-local-dev

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ─── Frontend URLs ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
