// GoodLifeTask — Prisma Schema
// Database: PostgreSQL (Aurora)
// Generator: Prisma Client (TypeScript)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum UserPlan {
  free
  pro
  team
  family
}

enum AuthProvider {
  email
  google
  apple
  microsoft
}

enum ThemePreference {
  warm_corporate
  blue_spectrum
  india
  usa
}

enum ReminderType {
  call
  task
  email
  location
  event
}

enum ReminderStatus {
  pending
  completed
  snoozed
  deleted
}

enum ReminderPriority {
  low
  medium
  high
  urgent
}

enum RecurrenceFrequency {
  daily
  weekly
  monthly
  yearly
  custom
}

enum NotificationChannel {
  push
  email
  sms
}

enum NotificationStatus {
  queued
  sent
  delivered
  failed
  clicked
}

enum NotificationAction {
  none
  snoozed
  dismissed
  acted
}

enum Platform {
  ios
  android
  web
}

enum CalendarProvider {
  google
  outlook
  icloud
  caldav
}

enum CalendarSyncStatus {
  active
  error
  paused
  disconnected
}

enum SubscriptionProvider {
  stripe
  revenuecat
  manual
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
  expired
}

enum GeofenceTrigger {
  enter
  exit
  both
}

enum UserRole {
  user
  super_admin
  administrator
  moderator
  support_agent
  read_only
}

enum AdminRole {
  super_admin
  administrator
  moderator
  support
  read_only
}

enum TeamMemberRole {
  owner
  admin
  member
}

enum UserPersona {
  student
  teacher
  nurse
  doctor
  engineer
  carpenter
  chef
  developer
  manager
  entrepreneur
  parent
  retiree
  other
}

enum FamilyMemberRole {
  owner
  adult
  child
}

enum FamilyInviteStatus {
  pending
  accepted
  declined
  expired
}

enum ReminderShareScope {
  private
  family
  team
  specific
}

// ─── USERS ──────────────────────────────────────────────────────────────────

model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique @db.VarChar(255)
  name         String       @db.VarChar(100)
  passwordHash String?      @map("password_hash") @db.VarChar(255)
  avatarUrl    String?      @map("avatar_url") @db.VarChar(500)
  plan         UserPlan     @default(free)
  role         UserRole     @default(user)
  authProvider AuthProvider @default(email) @map("auth_provider")
  locale       String       @default("en") @db.VarChar(10)
  timezone     String       @default("UTC") @db.VarChar(50)
  theme        ThemePreference @default(warm_corporate)
  isActive     Boolean      @default(true) @map("is_active")

  // Individual profile / persona
  persona          UserPersona?
  occupation       String?   @db.VarChar(100)   // free-text job title
  profileCategory  String?   @map("profile_category") @db.VarChar(60)
  profileSubType   String?   @map("profile_sub_type")  @db.VarChar(100)
  taskPreferences  Json      @default("[]")     @map("task_preferences")

  // 2FA / biometric
  totpSecret   String?      @map("totp_secret") @db.VarChar(255) // encrypted

  // Settings JSON (notification prefs, quiet hours, etc.)
  settings     Json         @default("{}")

  // Password reset
  passwordResetToken   String?   @map("password_reset_token") @db.VarChar(255)
  passwordResetExpires DateTime? @map("password_reset_expires")

  // Timestamps
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")    // soft delete (GDPR)
  lastLoginAt  DateTime?    @map("last_login_at")

  // Relations
  reminders           Reminder[]
  reminderLists       ReminderList[]
  contacts            Contact[]
  locations           Location[]
  recurrenceRules     RecurrenceRule[]
  notificationLogs    NotificationLog[]
  pushDeviceTokens    PushDeviceToken[]
  calendarIntegrations CalendarIntegration[]
  emailIntegrations   EmailIntegration[]
  subscription        Subscription?
  oauthAccounts       OAuthAccount[]
  refreshTokens       RefreshToken[]
  teamMemberships     TeamMembership[]
  ownedWorkspaces     TeamWorkspace[]
  familyMemberships   FamilyMember[]
  ownedFamilies       Family[]         @relation("FamilyOwner")
  reminderShares      ReminderShare[]
  assignedReminders   Reminder[]       @relation("AssignedReminders")

  @@index([email])
  @@index([plan])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model OAuthAccount {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  provider     AuthProvider
  providerId   String       @map("provider_id") @db.VarChar(255) // external user ID
  accessToken  String?      @map("access_token") @db.Text      // encrypted
  refreshToken String?      @map("refresh_token") @db.Text     // encrypted
  expiresAt    DateTime?    @map("expires_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash") @db.VarChar(255) // SHA-256 hash
  userAgent   String?   @map("user_agent") @db.VarChar(500)
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ─── REMINDERS ──────────────────────────────────────────────────────────────

model ReminderList {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  name      String    @db.VarChar(50)
  color     String    @default("#F0A202") @db.VarChar(7)
  icon      String    @default("list") @db.VarChar(50)
  isSystem  Boolean   @default(false) @map("is_system")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders Reminder[]

  @@index([userId])
  @@map("reminder_lists")
}

model RecurrenceRule {
  id              String              @id @default(uuid()) @db.Uuid
  userId          String              @map("user_id") @db.Uuid
  frequency       RecurrenceFrequency
  interval        Int                 @default(1)
  daysOfWeek      Int[]               @map("days_of_week")     // 0=Sun...6=Sat
  dayOfMonth      Int?                @map("day_of_month")
  monthOfYear     Int?                @map("month_of_year")
  endDate         DateTime?           @map("end_date")
  maxOccurrences  Int?                @map("max_occurrences")
  rruleString     String              @map("rrule_string") @db.VarChar(500)
  createdAt       DateTime            @default(now()) @map("created_at")

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders       Reminder[]

  @@index([userId])
  @@map("recurrence_rules")
}

model Contact {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  name      String    @db.VarChar(100)
  email     String?   @db.VarChar(255)
  phone     String?   @db.VarChar(30)
  avatarUrl String?   @map("avatar_url") @db.VarChar(500)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders Reminder[]

  @@index([userId])
  @@index([userId, name])
  @@map("contacts")
}

model Location {
  id           String          @id @default(uuid()) @db.Uuid
  userId       String          @map("user_id") @db.Uuid
  name         String          @db.VarChar(100)
  address      String          @db.VarChar(500)
  latitude     Float
  longitude    Float
  radiusMeters Int             @default(100) @map("radius_meters")
  triggerType  GeofenceTrigger @default(enter) @map("trigger_type")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders    Reminder[]

  @@index([userId])
  @@map("locations")
}

model Reminder {
  id           String          @id @default(uuid()) @db.Uuid
  userId       String          @map("user_id") @db.Uuid
  listId       String?         @map("list_id") @db.Uuid
  recurrenceId String?         @map("recurrence_id") @db.Uuid
  contactId    String?         @map("contact_id") @db.Uuid
  locationId   String?         @map("location_id") @db.Uuid

  type         ReminderType
  title        String          @db.VarChar(255)
  notes        String?         @db.Text
  status       ReminderStatus  @default(pending)
  priority     ReminderPriority @default(medium)

  fireAt       DateTime        @map("fire_at") @db.Timestamptz
  snoozedUntil DateTime?       @map("snoozed_until") @db.Timestamptz
  completedAt  DateTime?       @map("completed_at") @db.Timestamptz

  // Type-specific data stored as JSONB
  metadata     Json            @default("{}")

  // Sharing
  workspaceId  String?            @map("workspace_id") @db.Uuid
  projectId    String?            @map("project_id") @db.Uuid
  familyId     String?            @map("family_id") @db.Uuid
  assigneeId   String?            @map("assignee_id") @db.Uuid   // who the task is assigned to
  shareScope   ReminderShareScope @default(private) @map("share_scope")

  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")

  // Relations
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  list         ReminderList?   @relation(fields: [listId], references: [id], onDelete: SetNull)
  recurrence   RecurrenceRule? @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)
  contact      Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  location     Location?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  workspace    TeamWorkspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  project      TeamProject?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  family       Family?         @relation(fields: [familyId], references: [id], onDelete: SetNull)
  assignee     User?           @relation("AssignedReminders", fields: [assigneeId], references: [id], onDelete: SetNull)
  shares       ReminderShare[]
  notifications NotificationLog[]

  @@index([userId, fireAt], name: "idx_reminders_user_fire_at")
  @@index([userId, status], name: "idx_reminders_user_status")
  @@index([userId, type])
  @@index([fireAt], name: "idx_reminders_fire_at")  // for scheduler
  @@index([deletedAt])
  @@map("reminders")
}

// ─── NOTIFICATIONS ──────────────────────────────────────────────────────────

model PushDeviceToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  platform   Platform
  token      String    @db.Text      // FCM token, APNs device token, or VAPID subscription JSON
  isActive   Boolean   @default(true) @map("is_active")
  appVersion String?   @map("app_version") @db.VarChar(20)
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, token])
  @@index([userId], name: "idx_push_tokens_user")
  @@index([token])
  @@map("push_device_tokens")
}

model NotificationLog {
  id          String             @id @default(uuid()) @db.Uuid
  reminderId  String             @map("reminder_id") @db.Uuid
  userId      String             @map("user_id") @db.Uuid
  channel     NotificationChannel
  status      NotificationStatus @default(queued)
  providerId  String?            @map("provider_id") @db.VarChar(255) // FCM/APNs message ID
  errorCode   String?            @map("error_code") @db.VarChar(100)
  errorMessage String?           @map("error_message") @db.Text
  sentAt      DateTime?          @map("sent_at")
  deliveredAt DateTime?          @map("delivered_at")
  actionTaken NotificationAction @default(none) @map("action_taken")
  createdAt   DateTime           @default(now()) @map("created_at")

  reminder    Reminder           @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reminderId, status], name: "idx_notif_logs_reminder")
  @@index([userId, createdAt(sort: Desc)])
  @@map("notification_logs")
}

// ─── INTEGRATIONS ───────────────────────────────────────────────────────────

model CalendarIntegration {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @map("user_id") @db.Uuid
  provider        CalendarProvider
  calendarId      String            @map("calendar_id") @db.VarChar(500)
  calendarName    String?           @map("calendar_name") @db.VarChar(255)
  accessToken     String            @map("access_token") @db.Text      // encrypted
  refreshToken    String?           @map("refresh_token") @db.Text     // encrypted
  tokenExpiresAt  DateTime?         @map("token_expires_at")
  syncToken       String?           @map("sync_token") @db.Text        // incremental sync token
  webhookId       String?           @map("webhook_id") @db.VarChar(255)
  lastSyncedAt    DateTime?         @map("last_synced_at")
  syncStatus      CalendarSyncStatus @default(active) @map("sync_status")
  errorMessage    String?           @map("error_message") @db.Text
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, calendarId])
  @@index([userId], name: "idx_calendar_integrations_user")
  @@map("calendar_integrations")
}

model EmailIntegration {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  provider     String       @db.VarChar(50)  // gmail, outlook
  email        String       @db.VarChar(255)
  accessToken  String       @map("access_token") @db.Text   // encrypted
  refreshToken String?      @map("refresh_token") @db.Text  // encrypted
  tokenExpiresAt DateTime?  @map("token_expires_at")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("email_integrations")
}

// ─── SUBSCRIPTIONS & BILLING ────────────────────────────────────────────────

model Subscription {
  id                String               @id @default(uuid()) @db.Uuid
  userId            String               @unique @map("user_id") @db.Uuid
  plan              UserPlan             @default(free)
  status            SubscriptionStatus   @default(active)
  provider          SubscriptionProvider?
  externalId        String?              @map("external_id") @db.VarChar(255) // Stripe sub ID
  currentPeriodStart DateTime?           @map("current_period_start")
  currentPeriodEnd  DateTime?            @map("current_period_end")
  cancelAtPeriodEnd Boolean              @default(false) @map("cancel_at_period_end")
  canceledAt        DateTime?            @map("canceled_at")
  trialEndsAt       DateTime?            @map("trial_ends_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([externalId])
  @@index([status])
  @@map("subscriptions")
}

model WebhookEvent {
  id          String    @id @default(uuid()) @db.Uuid
  provider    String    @db.VarChar(50)   // stripe, revenuecat
  eventId     String    @unique @map("event_id") @db.VarChar(255)  // provider's event ID
  eventType   String    @map("event_type") @db.VarChar(100)
  payload     Json
  processedAt DateTime? @map("processed_at")
  error       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([provider, eventType])
  @@map("webhook_events")
}

// ─── TEAM PLAN ───────────────────────────────────────────────────────────────

model TeamWorkspace {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(100)
  description String?   @db.Text
  avatarUrl   String?   @map("avatar_url") @db.VarChar(500)
  ownerId     String    @map("owner_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  owner     User      @relation(fields: [ownerId], references: [id])
  members   TeamMembership[]
  projects  TeamProject[]
  reminders Reminder[]

  @@map("team_workspaces")
}

model TeamProject {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  name        String        @db.VarChar(100)
  description String?       @db.Text
  color       String        @default("#6366f1") @db.VarChar(7)
  icon        String        @default("folder") @db.VarChar(50)
  isArchived  Boolean       @default(false) @map("is_archived")
  dueDate     DateTime?     @map("due_date")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  workspace   TeamWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reminders   Reminder[]

  @@index([workspaceId])
  @@map("team_projects")
}

model TeamMembership {
  workspaceId String         @map("workspace_id") @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  role        TeamMemberRole @default(member)
  joinedAt    DateTime       @default(now()) @map("joined_at")

  workspace   TeamWorkspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
  @@map("team_memberships")
}

// ─── FAMILY PLAN ─────────────────────────────────────────────────────────────

model Family {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(100)
  avatarUrl String?   @map("avatar_url") @db.VarChar(500)
  ownerId   String    @map("owner_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  owner     User           @relation("FamilyOwner", fields: [ownerId], references: [id])
  members   FamilyMember[]
  invites   FamilyInvite[]
  reminders Reminder[]

  @@map("families")
}

model FamilyMember {
  familyId  String           @map("family_id") @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  role      FamilyMemberRole @default(adult)
  nickname  String?          @db.VarChar(50)
  joinedAt  DateTime         @default(now()) @map("joined_at")

  family    Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([familyId, userId])
  @@index([userId])
  @@map("family_members")
}

model FamilyInvite {
  id        String             @id @default(uuid()) @db.Uuid
  familyId  String             @map("family_id") @db.Uuid
  email     String             @db.VarChar(255)
  tokenHash String             @unique @map("token_hash") @db.VarChar(255)
  role      FamilyMemberRole   @default(adult)
  status    FamilyInviteStatus @default(pending)
  expiresAt DateTime           @map("expires_at")
  createdAt DateTime           @default(now()) @map("created_at")

  family    Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([email])
  @@map("family_invites")
}

model ReminderShare {
  reminderId String   @map("reminder_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  canEdit    Boolean  @default(false) @map("can_edit")
  sharedAt   DateTime @default(now()) @map("shared_at")

  reminder   Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([reminderId, userId])
  @@index([userId])
  @@map("reminder_shares")
}

// ─── ADMIN ───────────────────────────────────────────────────────────────────

model AdminUser {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @unique @db.VarChar(255)
  name        String    @db.VarChar(100)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role        AdminRole @default(read_only)
  isActive    Boolean   @default(true) @map("is_active")
  mfaSecret   String?   @map("mfa_secret") @db.VarChar(255) // encrypted
  mfaEnabled  Boolean   @default(false) @map("mfa_enabled")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  auditLogs   AuditLog[]

  @@map("admin_users")
}

model AuditLog {
  id         String    @id @default(uuid()) @db.Uuid
  actorId    String    @map("actor_id") @db.Uuid
  action     String    @db.VarChar(100)   // e.g. "user.ban", "plan.change"
  resource   String    @db.VarChar(50)    // e.g. "user", "subscription"
  resourceId String?   @map("resource_id") @db.Uuid
  oldValue   Json?     @map("old_value")
  newValue   Json?     @map("new_value")
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  userAgent  String?   @map("user_agent") @db.VarChar(500)
  createdAt  DateTime  @default(now()) @map("created_at")

  actor      AdminUser @relation(fields: [actorId], references: [id])

  // Append-only: no updates or deletes permitted (enforced at application layer)
  @@index([actorId, createdAt(sort: Desc)], name: "idx_audit_logs_actor")
  @@index([resource, resourceId])
  @@index([action])
  @@map("audit_logs")
}

// ─── COUNTRIES & LANGUAGES ──────────────────────────────────────────────────

model Country {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @unique @db.VarChar(100)
  code      String     @unique @db.VarChar(3)    // ISO 3166-1 alpha-2/3
  sortOrder Int        @default(0) @map("sort_order")
  languages Language[]

  @@map("countries")
}

model Language {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(100)
  code        String   @db.VarChar(20)           // BCP-47 / ISO 639-1
  countryId   String   @map("country_id") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  isRtl       Boolean  @default(false) @map("is_rtl")
  sortOrder   Int      @default(0) @map("sort_order")

  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, name])
  @@index([countryId])
  @@map("languages")
}

// ─── TRANSLATIONS ────────────────────────────────────────────────────────────

// A translatable string key in the app (menu item, heading, button label, etc.)
model TranslationKey {
  id           String   @id @default(uuid()) @db.Uuid
  key          String   @unique @db.VarChar(255)    // e.g. "nav.dashboard", "btn.save"
  namespace    String   @default("common") @db.VarChar(50) // nav | page | btn | form | badge | msg | table
  description  String?  @db.Text                   // human-readable description of where/what
  defaultValue String   @map("default_value") @db.Text   // English (source) string
  isStatic     Boolean  @default(true) @map("is_static")  // false = dynamic (user-generated content)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  translations Translation[]

  @@index([namespace])
  @@index([isActive])
  @@map("translation_keys")
}

// A translated value for a specific key + language code
model Translation {
  id          String   @id @default(uuid()) @db.Uuid
  keyId       String   @map("key_id") @db.Uuid
  langCode    String   @map("lang_code") @db.VarChar(20)  // BCP-47, e.g. "en", "fr", "ar"
  value       String   @db.Text                            // translated string
  isApproved  Boolean  @default(true) @map("is_approved") // false = needs review
  updatedBy   String?  @map("updated_by") @db.VarChar(255) // admin email who last edited
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  translationKey TranslationKey @relation(fields: [keyId], references: [id], onDelete: Cascade)

  @@unique([keyId, langCode])
  @@index([langCode])
  @@index([keyId])
  @@map("translations")
}

model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(100)
  keyHash     String    @unique @map("key_hash") @db.VarChar(255) // SHA-256 hash
  keyPrefix   String    @map("key_prefix") @db.VarChar(15)       // first chars for display
  description String?   @db.Text
  permissions String[]  // JSON array of permission scopes
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdBy   String    @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([keyHash])
  @@map("api_keys")
}
