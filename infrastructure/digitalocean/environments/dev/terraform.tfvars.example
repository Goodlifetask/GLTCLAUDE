# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git

do_token      = "dop_v1_your_token_here"
region        = "nyc3"
ssh_key_ids   = ["12345678"]   # Get from: doctl compute ssh-key list
jwt_secret    = "change-me-to-a-long-random-string-at-least-64-chars"
spaces_key    = "your_spaces_access_key"
spaces_secret = "your_spaces_secret_key"
frontend_url  = "http://YOUR_DROPLET_IP:3000"
anthropic_key = "sk-ant-api03-your-key-here"
